# Repro 03 — Docker persistence, permissions & upgrades
# ------------------------------------------------------
# Copy to .env and edit. Both docker-compose.yml (broken) and
# docker-compose.fixed.yml (fixed) read from the same .env file.

# Host port the n8n container publishes to. Change if 5678 is taken.
PUBLIC_PORT=5678

# --- The single most important env var for credential portability ---
# Generate ONE value and pin it. Back it up alongside your /home/node/.n8n
# volume — without it, your credentials cannot be decrypted.
#
# To generate a fresh one:
#   openssl rand -hex 32
#
# The broken stack (docker-compose.yml) deliberately ignores this var and
# lets n8n auto-generate a key inside the (non-existent) volume — which is
# how thousands of users have lost credentials between routine restarts.
N8N_ENCRYPTION_KEY=replace-me-with-the-output-of-openssl-rand-hex-32

# --- Standard n8n config (kept simple for the repro) ---
GENERIC_TIMEZONE=America/New_York
N8N_BASIC_AUTH_ACTIVE=false
N8N_RUNNERS_ENABLED=true
N8N_DIAGNOSTICS_ENABLED=false

# --- Optional: Postgres connection (only needed if you migrate per WORKAROUND.md Step 5) ---
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=postgres
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=n8n
# DB_POSTGRESDB_USER=n8n
# DB_POSTGRESDB_PASSWORD=replace-me
