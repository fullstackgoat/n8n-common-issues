# --- Public hostname customers care about ---
# In real deployments this is your domain; here we simulate it via /etc/hosts or just localhost.
PUBLIC_HOST=localhost

# Port the reverse proxy listens on (host port). n8n itself stays on 5678 inside the network.
PUBLIC_PORT=8080

# --- The four env vars that fix the entire issue ---
# These are intentionally MISSING from docker-compose.yml so you can see the bug,
# and PRESENT in docker-compose.fixed.yml so you can see the fix.

# N8N_HOST=localhost
# N8N_PROTOCOL=http
# N8N_PORT=5678
# WEBHOOK_URL=http://localhost:8080/

# --- Optional but commonly needed ---
# N8N_PROXY_HOPS=1            # set if behind multiple proxies (Cloudflare in front of nginx etc.)
# N8N_EDITOR_BASE_URL=http://localhost:8080/

# --- Standard n8n config (kept simple for the repro) ---
GENERIC_TIMEZONE=America/New_York
N8N_BASIC_AUTH_ACTIVE=false
N8N_RUNNERS_ENABLED=true
N8N_DIAGNOSTICS_ENABLED=false
