# Repro 08 — HTTP Request: ECONNREFUSED, proxies & self-signed certs
# -------------------------------------------------------------------
# Copy to .env and edit. Both docker-compose.yml (broken) and
# docker-compose.fixed.yml (fixed) read from the same .env file.

# Host port for the n8n editor. Change if 5678 is taken.
PUBLIC_PORT=5678

# --- Standard n8n config (kept simple for the repro) ---
GENERIC_TIMEZONE=America/New_York
N8N_BASIC_AUTH_ACTIVE=false
N8N_RUNNERS_ENABLED=true
N8N_DIAGNOSTICS_ENABLED=false

# --- Notes ---
# fake-ollama publishes to 11434 on the host. If you're already running
# real Ollama on this machine, that port collision will fail the boot.
# Either stop your real Ollama for the duration of the repro, or change
# the published port in docker-compose*.yml (and the workflow URLs).
#
# squid listens on 3128 inside the docker network (not published to host).
# self-signed-nginx listens on 443 inside the docker network (not published).
# Both are reachable from n8n via Docker's embedded DNS.
