# Repro 07 — Loops, iteration & data-shape errors
# ------------------------------------------------
# The three workflow JSONs in workflows/ can be imported into ANY n8n
# instance, including n8n cloud. This compose stack is only here for users
# who'd prefer a local container. If that's you, copy this file to .env:
#
#     cp .env.example .env
#
# …then `docker compose up -d` and open http://localhost:5678 .

# Host port the local n8n container publishes to. Change if 5678 is taken.
PUBLIC_PORT=5678

# Standard n8n config — matches the project-wide template.
GENERIC_TIMEZONE=America/New_York
N8N_BASIC_AUTH_ACTIVE=false
N8N_RUNNERS_ENABLED=true
N8N_DIAGNOSTICS_ENABLED=false
